# =============================================================================
# Database port exposure configuration
# =============================================================================
# Por defecto los puertos están vinculados SOLO a localhost (127.0.0.1).
# Para exponer en todas las interfaces (acceso externo), cambia a 0.0.0.0:PUERTO
#
# Uso: estas variables se leen automáticamente por docker compose
# cuando se ejecuta desde este directorio.
# =============================================================================

# PostgreSQL (activo por defecto con postgres-infra)
EXPOSE_POSTGRES_PORT=127.0.0.1:5432

# MongoDB
EXPOSE_MONGO_PORT=0.0.0.0:27017

# Redis
EXPOSE_REDIS_PORT=127.0.0.1:6379

# Neo4j - Bolt protocol (acceso desde drivers/DBeaver)
EXPOSE_NEO4J_BOLT=127.0.0.1:7687

# DuckDB REST API
EXPOSE_DUCKDB_PORT=127.0.0.1:8765

# =============================================================================
# Para iniciar SOLO una base de datos (sin el stack completo):
#
#   docker compose -f infra/databases/mongodb/docker-compose.yml up -d
#   docker compose -f infra/databases/postgres/docker-compose.yml up -d
#   docker compose -f infra/databases/neo4j/docker-compose.yml up -d
#   docker compose -f infra/databases/duckdb/docker-compose.yml up -d
#   docker compose -f infra/databases/redis/docker-compose.yml up -d
#
# Requiere que infra-network exista:
#   docker network create infra-network
# =============================================================================
